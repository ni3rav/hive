{
  "name": "@hive/query-params",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "description": "Query param utilities for Hive monorepo",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./react-router": {
      "import": "./dist/react-router.js",
      "require": "./dist/react-router.cjs"
    },
    "./vanilla": {
      "import": "./dist/vanilla.js",
      "require": "./dist/vanilla.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-router-dom": ">=6.0.0"
  },
  "peerDependenciesMeta": {
    "react-router-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.1.8",
    "jsdom": "^26.1.0",
    "react": "^19.1.2",
    "react-router-dom": "^7.7.1",
    "tsdown": "^0.21.3",
    "typescript": "^5.9.2",
    "vitest": "^3.2.7"
  }
}
