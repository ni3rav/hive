{
  "name": "hive-cms",
  "type": "module",
  "version": "1.2.1",
  "private": false,
  "description": "Type-safe Node.js SDK for Hive CMS public API.",
  "homepage": "https://hivecms.online/docs",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ni3rav/hive.git",
    "directory": "packages/sdk"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=20"
  },
  "browser": false,
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "pnpm build && node --test tests/**/*.test.mjs"
  },
  "devDependencies": {
    "@types/node": "^25.9.5",
    "tsdown": "^0.21.10",
    "typescript": "^5.9.3"
  }
}
